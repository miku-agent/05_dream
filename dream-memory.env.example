# Dream Memory System v0 example env
DREAM_MEMORY_TZ=Asia/Seoul
DREAM_MEMORY_ROOT=/Users/bini/.openclaw/workspace
DREAM_SESSIONS_DIR=/Users/bini/.openclaw/agents/miku/sessions
DREAM_LIMIT=20
DREAM_ARCHIVE_TO_SUPABASE=false
DREAM_WRITE_PROMOTIONS=false
DREAM_PURGE_DRY_RUN=false

# LLM Semantic Scorer (Gemini)
GEMINI_API_KEY=
DREAM_LLM_MODEL=gemini-2.0-flash-lite
# scorer mode: llm | heuristic | auto (default: auto — uses llm if GEMINI_API_KEY is set)
DREAM_SCORER_MODE=auto

# Embedding Generation
# provider: local (stub, no vectors) | gemini (real vectors via Gemini API)
DREAM_EMBEDDING_PROVIDER=gemini
DREAM_EMBEDDING_MODEL=text-embedding-004

# Supabase raw archive
DREAM_SUPABASE_URL=
DREAM_SUPABASE_SERVICE_ROLE_KEY=
DREAM_ARCHIVE_BUCKET=dream-archive
DREAM_RETENTION_EPHEMERAL_DAYS=14
DREAM_RETENTION_STANDARD_DAYS=60
DREAM_RETENTION_PROMOTED_DAYS=180
